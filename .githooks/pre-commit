#!/bin/sh
set -eu

if [ "${ALLOW_NON_MAIN_BRANCH:-}" = "1" ]; then
  exit 0
fi

branch="$(git branch --show-current 2>/dev/null || true)"
if [ -z "$branch" ]; then
  echo "TakSklad guard: detached HEAD. Commit blocked; switch to main or set ALLOW_NON_MAIN_BRANCH=1 for an explicitly approved exception." >&2
  exit 1
fi

if [ "$branch" != "main" ]; then
  echo "TakSklad guard: commits are allowed only on main. Current branch: $branch" >&2
  echo "Switch to main, or set ALLOW_NON_MAIN_BRANCH=1 only for an explicitly approved exception." >&2
  exit 1
fi

python_bin="python3"
if [ -x ".venv/bin/python" ]; then
  python_bin=".venv/bin/python"
fi

PYTHONDONTWRITEBYTECODE=1 PYTHONPATH=. "$python_bin" \
  tools/check_release_tree.py --staged --strict --path-only

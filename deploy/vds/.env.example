TAKSKLAD_ENV=staging
TAKSKLAD_SERVICE_NAME=taksklad-backend
TAKSKLAD_API_TOKEN=change-me-service-token
TAKSKLAD_ENV_FILE=.env.example
TAKSKLAD_TIMEZONE=Asia/Tashkent

POSTGRES_DB=taksklad
POSTGRES_USER=taksklad
POSTGRES_PASSWORD=change-me-postgres-password
DATABASE_URL=postgresql+psycopg://taksklad:change-me-postgres-password@postgres:5432/taksklad

TAKSKLAD_BACKEND_HOST=api.example.com
TAKSKLAD_FRONTEND_HOST=app.example.com
TAKSKLAD_FRONTEND_WWW_HOST=www.app.example.com
TAKSKLAD_PUBLIC_API_URL=
TAKSKLAD_CORS_ORIGINS=https://app.example.com
TAKSKLAD_ADMINER_HOST=adminer.example.com
TRAEFIK_NETWORK=traefik
TAKSKLAD_WEB_LOGIN=
TAKSKLAD_WEB_PASSWORD_HASH=
TAKSKLAD_WEB_SESSION_SECRET=change-me-web-session-secret
TAKSKLAD_WEB_SESSION_TTL_SECONDS=86400
TAKSKLAD_WEB_COOKIE_SECURE=true
TAKSKLAD_WEB_LOGIN_MAX_ATTEMPTS=5
TAKSKLAD_WEB_LOGIN_WINDOW_SECONDS=300
TAKSKLAD_WEB_LOGIN_LOCK_SECONDS=900
YANDEX_GEOCODER_API_KEY=
TAKSKLAD_GOOGLE_SPREADSHEET_ID=
TAKSKLAD_GOOGLE_SHEET_NAME=data
TAKSKLAD_GOOGLE_CREDENTIALS_JSON_BASE64=
TAKSKLAD_GOOGLE_API_TIMEOUT_SECONDS=8
GOOGLE_SHEETS_SYNC_INTERVAL_SECONDS=60
TAKSKLAD_GOOGLE_TO_BACKEND_SYNC_ENABLED=false

SKLADBOT_API_TOKEN=
SKLADBOT_API_TOKENS=
SKLADBOT_CREATE_REQUESTS_MODE=dry_run
SKLADBOT_API_BASE_URL=https://api.skladbot.ru/v1
SKLADBOT_API_TIMEOUT_SECONDS=8
SKLADBOT_API_MAX_RETRIES=2
SKLADBOT_REQUEST_DELAY_SECONDS=2
SKLADBOT_TOKEN_SWITCH_DELAY_SECONDS=0
SKLADBOT_MAX_COOLDOWN_WAIT_SECONDS=5
SKLADBOT_CUSTOMER_ID=6211
SKLADBOT_SHIPMENT_TYPE_ID=3389
SKLADBOT_SYNC_LOOKBACK_DAYS=1
SKLADBOT_SYNC_MAX_LOOKBACK_DAYS=7
SKLADBOT_ORDER_CREATE_LEAD_DAYS=3
SKLADBOT_DETAIL_LIMIT=10
SKLADBOT_COMPLETED_BACKFILL_DAYS=2
SKLADBOT_REQUESTS_LIMIT=500
SKLADBOT_WORKER_INTERVAL_SECONDS=60

TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_CHAT_IDS=
TELEGRAM_ADMIN_CHAT_IDS=
TELEGRAM_WORKER_TIMEOUT_SECONDS=20
TELEGRAM_WORKER_POLL_TIMEOUT_SECONDS=15
TELEGRAM_WORKER_FILE_TIMEOUT_SECONDS=120
TELEGRAM_WORKER_MAX_FILE_BYTES=20971520
TAKSKLAD_DEFAULT_PIECES_PER_BLOCK=10
TAKSKLAD_DEFAULT_BLOCK_PRICE=240000

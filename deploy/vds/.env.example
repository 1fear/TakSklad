TAKSKLAD_ENV=staging
TAKSKLAD_SERVICE_NAME=taksklad-backend
TAKSKLAD_API_TOKEN=change-me-service-token
TAKSKLAD_ENV_FILE=.env.example

POSTGRES_DB=taksklad
POSTGRES_USER=taksklad
POSTGRES_PASSWORD=change-me-postgres-password
DATABASE_URL=postgresql+psycopg://taksklad:change-me-postgres-password@postgres:5432/taksklad

TAKSKLAD_BACKEND_HOST=api.example.com
TAKSKLAD_FRONTEND_HOST=app.example.com
TAKSKLAD_FRONTEND_BASIC_AUTH=anton:{SHA}change-me-htpasswd-sha1
TAKSKLAD_PUBLIC_API_URL=
TAKSKLAD_CORS_ORIGINS=https://app.example.com
TAKSKLAD_ADMINER_HOST=adminer.example.com
TRAEFIK_NETWORK=traefik
YANDEX_GEOCODER_API_KEY=

SKLADBOT_API_TOKEN=
SKLADBOT_API_BASE_URL=https://api.skladbot.ru/v1
SKLADBOT_API_TIMEOUT_SECONDS=8
SKLADBOT_API_MAX_RETRIES=2
SKLADBOT_REQUEST_DELAY_SECONDS=0.25
SKLADBOT_CUSTOMER_ID=6211
SKLADBOT_SHIPMENT_TYPE_ID=3389
SKLADBOT_SYNC_LOOKBACK_DAYS=1
SKLADBOT_REQUESTS_LIMIT=500
SKLADBOT_WORKER_INTERVAL_SECONDS=60

TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_CHAT_IDS=
TELEGRAM_ADMIN_CHAT_IDS=
TELEGRAM_WORKER_TIMEOUT_SECONDS=20
TELEGRAM_WORKER_POLL_TIMEOUT_SECONDS=15
TELEGRAM_WORKER_FILE_TIMEOUT_SECONDS=120
TELEGRAM_WORKER_MAX_FILE_BYTES=20971520
TAKSKLAD_DEFAULT_PIECES_PER_BLOCK=10
TAKSKLAD_DEFAULT_BLOCK_PRICE=240000

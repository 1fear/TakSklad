{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "repository", "mode", "mutation_allowed", "branch_rulesets", "environments"],
  "properties": {
    "schema_version": {"const": 1},
    "repository": {"const": "1fear/TakSklad"},
    "mode": {"const": "desired-read-only"},
    "mutation_allowed": {"const": false},
    "branch_rulesets": {
      "type": "array",
      "minItems": 1,
      "maxItems": 1,
      "items": {"type": "object"}
    },
    "environments": {
      "type": "array",
      "minItems": 1,
      "maxItems": 1,
      "items": {"type": "object"}
    }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "repository", "mode", "mutation_allowed", "branch_rulesets", "environments"],
  "properties": {
    "schema_version": {"const": 1},
    "repository": {"const": "1fear/TakSklad"},
    "mode": {"const": "desired-read-only"},
    "mutation_allowed": {"const": false},
    "branch_rulesets": {
      "type": "array",
      "minItems": 1,
      "maxItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "target", "enforcement", "bypass_actors", "conditions", "rules"],
        "properties": {
          "name": {"const": "TakSklad main release gate"},
          "target": {"const": "branch"},
          "enforcement": {"const": "active"},
          "bypass_actors": {"const": []},
          "conditions": {
            "type": "object",
            "additionalProperties": false,
            "required": ["ref_name"],
            "properties": {
              "ref_name": {
                "type": "object",
                "additionalProperties": false,
                "required": ["include", "exclude"],
                "properties": {
                  "include": {"const": ["refs/heads/main"]},
                  "exclude": {"const": []}
                }
              }
            }
          },
          "rules": {
            "type": "array",
            "minItems": 4,
            "maxItems": 4,
            "allOf": [
              {"contains": {"const": {"type": "deletion"}}, "minContains": 1, "maxContains": 1},
              {"contains": {"const": {"type": "non_fast_forward"}}, "minContains": 1, "maxContains": 1},
              {"contains": {"const": {"type": "required_linear_history"}}, "minContains": 1, "maxContains": 1},
              {
                "contains": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["type", "parameters"],
                  "properties": {
                    "type": {"const": "required_status_checks"},
                    "parameters": {
                      "type": "object",
                      "additionalProperties": false,
                      "required": ["strict_required_status_checks_policy", "do_not_enforce_on_create", "required_status_checks"],
                      "properties": {
                        "strict_required_status_checks_policy": {"const": true},
                        "do_not_enforce_on_create": {"const": false},
                        "required_status_checks": {"const": [{"context": "Release gate"}]}
                      }
                    }
                  }
                },
                "minContains": 1,
                "maxContains": 1
              }
            ]
          }
        }
      }
    },
    "environments": {
      "type": "array",
      "minItems": 1,
      "maxItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "wait_timer", "prevent_self_review", "can_admins_bypass", "required_reviewers", "deployment_branch_policy"],
        "properties": {
          "name": {"const": "production"},
          "wait_timer": {"const": 0},
          "prevent_self_review": {"const": false},
          "can_admins_bypass": {"const": false},
          "required_reviewers": {"const": [{"type": "User", "login": "1fear"}]},
          "deployment_branch_policy": {
            "const": {"protected_branches": true, "custom_branch_policies": false}
          }
        }
      }
    }
  }
}
